    {
      "id": 40,
      "nameKor": "마태복음",
      "nameEng": "Matthew",
      "chapters": [
        {
          "number": 1,
          "verses": [
            {"number": 1, "text": "아브라함과 다윗의 자손 예수 그리스도의 계보라"},
            {"number": 2, "text": "아브라함이 이삭을 낳고 이삭은 야곱을 낳고 야곱은 유다와 그의 형제들을 낳고"},
            {"number": 3, "text": "유다는 다말에게서 베레스와 세라를 낳고 베레스는 헤스론을 낳고 헤스론은 람을 낳고"},
            {"number": 4, "text": "람은 아미나답을 낳고 아미나답은 나손을 낳고 나손은 살몬을 낳고"},
            {"number": 5, "text": "살몬은 라합에게서 보아스를 낳고 보아스는 룻에게서 오벳을 낳고 오벳은 이새를 낳고"},
            {"number": 6, "text": "이새는 다윗 왕을 낳으니라 다윗은 우리야의 아내에게서 솔로몬을 낳고"},
            {"number": 7, "text": "솔로몬은 르호보암을 낳고 르호보암은 아비야를 낳고 아비야는 아사를 낳고"},
            {"number": 8, "text": "아사는 여호사밧을 낳고 여호사밧은 요람을 낳고 요람은 웃시야를 낳고"},
            {"number": 9, "text": "웃시야는 요담을 낳고 요담은 아하스를 낳고 아하스는 히스기야를 낳고"},
            {"number": 10, "text": "히스기야는 므낫세를 낳고 므낫세는 아몬을 낳고 아몬은 요시야를 낳고"}
          ]
        }
      ]
